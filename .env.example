# Required for API and DB access
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/waqf

# Optional: explicit admin seed on first run (recommended for fresh production setup)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me

# Backward-compatible optional keys still supported by codebase
# USER_NAME=admin
# PASSOWARD=change-me
# PASSWORD=change-me
